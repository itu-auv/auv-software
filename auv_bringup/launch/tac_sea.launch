<?xml version="1.0"?>
<launch>
  <arg name="namespace" default="taluy" />
  <arg name="sim" default="false" />
  <arg name="front_image_topic" default="/$(arg namespace)/cameras/cam_front/image_raw" />
  <arg name="bottom_image_topic" default="/$(arg namespace)/cameras/cam_bottom/image_raw" />
  <arg name="vitpose_model_path" default="$(find auv_detection)/models/valve2.engine" />
  <arg name="yolo_model_path" default="$(find auv_detection)/models/valve_yolo.pt" />
  <arg name="device" default="cuda:0" />
  <arg name="conf_threshold" default="0.5" />
  <arg name="yolo_conf_thres" default="0.25" />

  <group ns="$(arg namespace)">
    <!-- Front camera producer: image → KeypointResult tagged "valve_front" -->
    <node pkg="auv_vision" type="valve_keypoint_node.py"
          name="valve_keypoint_node_front" output="screen"
          unless="$(arg sim)">
      <param name="image_topic" value="$(arg front_image_topic)" />
      <param name="vitpose_model_path" value="$(arg vitpose_model_path)" />
      <param name="yolo_model_path" value="$(arg yolo_model_path)" />
      <param name="device" value="$(arg device)" />
      <param name="conf_threshold" value="$(arg conf_threshold)" />
      <param name="yolo_conf_thres" value="$(arg yolo_conf_thres)" />
      <param name="object_name" value="valve_front" />
      <param name="result_topic" value="/keypoint_result_front" />
      <param name="image_out_topic" value="/keypoint_image_front" />
    </node>

    <!-- Bottom camera producer: image → KeypointResult tagged "valve_bottom" -->
    <node pkg="auv_vision" type="valve_keypoint_node.py"
          name="valve_keypoint_node_bottom" output="screen"
          unless="$(arg sim)">
      <param name="image_topic" value="$(arg bottom_image_topic)" />
      <param name="vitpose_model_path" value="$(arg vitpose_model_path)" />
      <param name="yolo_model_path" value="$(arg yolo_model_path)" />
      <param name="device" value="$(arg device)" />
      <param name="conf_threshold" value="$(arg conf_threshold)" />
      <param name="yolo_conf_thres" value="$(arg yolo_conf_thres)" />
      <param name="object_name" value="valve_bottom" />
      <param name="result_topic" value="/keypoint_result_bottom" />
      <param name="image_out_topic" value="/keypoint_image_bottom" />
    </node>

    <!-- Single consumer handles both cameras + both valves
         (publishes tac/valve_front and tac/valve_bottom). -->
    <node pkg="auv_vision" type="keypoint_pose_node.py"
          name="keypoint_pose_node" output="screen">
      <param name="config_file" value="$(find auv_vision)/config/valve_keypoints.yaml" />
      <remap from="object_transform_updates" to="map/object_transform_updates" />
    </node>

    <!-- Single valve trajectory publisher for both front and bottom valves.
         Approach/engage frames use a look-at algorithm with mission_start_link
         as the roll/yaw reference — gimbal-lock-free for any table tilt. -->
    <node pkg="auv_mapping" type="valve_trajectory_publisher.py"
          name="valve_trajectory_publisher" output="screen">
      <param name="front_valve_frame" value="tac/valve_front" />
      <param name="front_approach_frame" value="valve_front_approach_target" />
      <param name="front_engage_frame" value="valve_front_engage_target" />
      <param name="front_approach_offset" value="0.3" />
      <param name="front_engage_offset" value="0.0" />
      <param name="bottom_valve_frame" value="tac/valve_bottom" />
      <param name="bottom_approach_frame" value="valve_bottom_approach_target" />
      <param name="bottom_engage_frame" value="valve_bottom_engage_target" />
      <param name="bottom_approach_offset" value="0.3" />
      <param name="bottom_engage_offset" value="0.0" />
      <remap from="set_object_transform" to="map/set_object_transform" />
    </node>

    <!-- Inspect trajectory publisher: 8 frames around the FRONT valve
         rectangle, all flattened to a configurable height above the valve's
         Z. Front-only by design (the rectangle geometry is hard-coded to the
         front panel). Toggled by smach via set_transform_inspect_frames. -->
    <node pkg="auv_mapping" type="inspect_trajectory_publisher.py"
          name="inspect_trajectory_publisher" output="screen">
      <param name="valve_frame" value="tac/valve_front" />
      <remap from="set_object_transform" to="map/set_object_transform" />
    </node>

    <!-- Gripper roll trackers: passively spin each valve gripper so the jaws
         match the tracked handle roll, starting the moment the valve TF frame
         appears (no SMACH involvement). Per-node services (under the node's
         private namespace): set_turn_direction (headroom pre-positioning),
         rotate (latched ramped turn), resume_tracking.
         ccw_sign / invert / offset_deg are bench-calibration knobs. -->
    <!-- Calibration (verified live on Taluy, front gripper, 2026-06-11):
         * invert=true — the camera sees the valve FACE, so the measured
           roll axis (flange normal) points back at the vehicle, anti-
           parallel to the gripper spin axis: mirrored handedness. Holds
           for both grippers (front: normal -X vs gripper +X; bottom:
           normal +Z vs gripper -Z).
         * offset_deg=90 — the servo's 550us zero actually holds the jaws
           in the cross-grip pose, 90 deg from the assumed zero direction.
           Same hardware/mount on both grippers; re-trim on the bottom if
           its mount differs. -->
    <node pkg="auv_control" type="gripper_roll_tracker.py"
          name="gripper_roll_tracker_front" output="screen">
      <param name="target_frame" value="tac/valve_front" />
      <param name="gripper_topic" value="/$(arg namespace)/actuators/gripper/set_angle" />
      <rosparam param="axis">[1.0, 0.0, 0.0]</rosparam>
      <rosparam param="feature_vector">[0.0, 0.0, 1.0]</rosparam>
      <rosparam param="reference_vector">[0.0, 0.0, 1.0]</rosparam>
      <param name="invert" value="true" />
      <param name="offset_deg" value="90.0" />
      <!-- Bench-calibrated 2026-06-11: commanded ccw turned the handle cw,
           so the servo runs opposite to the handle sense on this mount. -->
      <param name="ccw_sign" value="-1.0" />
    </node>

    <node pkg="auv_control" type="gripper_roll_tracker.py"
          name="gripper_roll_tracker_bottom" output="screen">
      <param name="target_frame" value="tac/valve_bottom" />
      <param name="gripper_topic" value="/$(arg namespace)/actuators/gripper1/set_angle" />
      <rosparam param="axis">[1.0, 0.0, 0.0]</rosparam>
      <rosparam param="feature_vector">[0.0, 0.0, 1.0]</rosparam>
      <!-- Bottom gripper points down: its zero direction is horizontal
           (body +X assumed; trim with offset_deg on the real mount). -->
      <rosparam param="reference_vector">[1.0, 0.0, 0.0]</rosparam>
      <param name="invert" value="true" />
      <param name="offset_deg" value="90.0" />
      <!-- NOT yet bench-verified for the bottom gripper — calibrate its
           handle-vs-servo sense before trusting a bottom-valve turn. -->
      <param name="ccw_sign" value="1.0" />
    </node>

    <!-- ArUco scan-only detector on the front camera (no pose estimation,
         just marker detection + debug images). -->
    <node pkg="auv_vision" type="aruco_detection_node.py"
          name="aruco_detection" output="screen">
      <param name="scan_mode" value="true" />
      <param name="aruco_dictionary" value="DICT_ARUCO_ORIGINAL" />
      <param name="image_topic" value="$(arg front_image_topic)" />
      <param name="camera_frame" value="$(arg namespace)/base_link/front_camera_optical_link_stabilized" />
    </node>
  </group>

</launch>
