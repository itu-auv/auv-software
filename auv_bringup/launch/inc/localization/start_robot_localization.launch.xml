<?xml version="1.0"?>
<launch>
  <arg name="namespace" default="taluy"/>
  <arg name="control_rate" default="20.0"/>
  <arg name="sim" default="false"/>

  <group ns="$(arg namespace)">
    <node pkg="robot_localization" type="ekf_localization_node" name="auv_localization_node" clear_params="true">
      <rosparam command="load" file="$(find auv_bringup)/config/ekf.yaml"/>
      <remap from="odometry/filtered" to="odometry"/>
      <remap from="accel/filtered" to="acceleration"/>
      <param name="disabled_at_startup" value="$(eval not arg('sim'))" type="bool"/>
      <param name="frequency" value="$(arg control_rate)" type="double"/>
    </node>

    <node pkg="robot_localization" type="ekf_localization_node" name="auv_localization_node_mti630" clear_params="true">
      <rosparam command="load" file="$(find auv_bringup)/config/ekf_mti630.yaml"/>
      <remap from="odometry/filtered" to="odometry_mti630"/>
      <remap from="accel/filtered" to="acceleration_mti630"/>
      <remap from="set_pose" to="set_pose_mti630"/>
      <param name="disabled_at_startup" value="$(eval not arg('sim'))" type="bool"/>
      <param name="frequency" value="$(arg control_rate)" type="double"/>
    </node>
  </group>
</launch>
