<?xml version="1.0"?>
<launch>
  <arg name="namespace" default="taluy_mini" />

  <group ns="$(arg namespace)">
    <node pkg="vectornav" type="vnpub" name="auv_vectornav_node" output="screen" >
        <rosparam command="load" file="$(find auv_bringup)/config/vn100.yaml" />
        <remap from="vectornav/IMU" to="sensors/imu/data"/>
    </node>
  </group>
</launch>
