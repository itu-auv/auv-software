<?xml version="1.0"?>
<launch>
  <arg name="namespace" default="taluy" />
  <arg name="control_rate" default="20.0" />
  <arg name="dvl_virtual_port" default="/tmp/vcom0" />
  <arg name="use_gui" default="false" />
  <arg name="enable_logging" default="true" />
  <arg name="logging_directory" default="$(optenv HOME)/bags" />
  <arg name="device" default="cuda:0" />
  <arg name="detection_config" default="$(find auv_vision)/config/detection_objects_tac.yaml" />
  <arg name="aruco_config" default="$(find auv_vision)/config/aruco_objects_tac.yaml" />
  <arg name="pool_depth" default="2.134" />

  <!-- 1. Include start.launch (hardware + navigation) -->
  <include file="$(find auv_bringup)/launch/start.launch">
    <arg name="namespace" value="$(arg namespace)" />
    <arg name="control_rate" value="$(arg control_rate)" />
    <arg name="dvl_virtual_port" value="$(arg dvl_virtual_port)" />
    <arg name="use_gui" value="$(arg use_gui)" />
    <arg name="enable_logging" value="$(arg enable_logging)" />
    <arg name="logging_directory" value="$(arg logging_directory)" />
    <arg name="detection_config" value="$(arg detection_config)" />
    <arg name="pool_depth" value="$(arg pool_depth)" />
  </include>

  <!-- 2. TAC Docking detection: YOLO tracker -->
  <include file="$(find auv_detection)/launch/inc/tracker_docking.launch">
    <arg name="device" value="$(arg device)" />
  </include>

  <!-- 3. TAC Docking detection: config-driven ArUco detection node -->
  <node pkg="auv_vision" type="aruco_detection_node.py"
        name="aruco_detection_node" output="screen">
    <param name="config_file" value="$(arg aruco_config)" />
    <remap from="object_transform_updates" to="/$(arg namespace)/map/object_transform_updates" />
  </node>
</launch>
