<launch>
  <arg name="namespace" default="taluy" />

  <include file="$(find auv_detection)/launch/inc/tracker_segment.launch">
    <arg name="namespace" value="$(arg namespace)" />
  </include>
  <include file="$(find auv_detection)/launch/inc/tracker_detection.launch">
    <arg name="namespace" value="$(arg namespace)" />
  </include>

  <group ns="$(arg namespace)">
    <node pkg="auv_vision" type="pipe_follower_legacy.py" name="pipe_follower_legacy" output="screen">
      <remap from="seg_mask" to="yolo_seg_to_mask/seg_mask" />
      <remap from="cmd_vel" to="cmd_vel" />
      <remap from="debug_image" to="pipe_follower_legacy/debug_image" />
      <remap from="align_frame/start" to="control/align_frame/start" />
      <remap from="align_frame/cancel" to="control/align_frame/cancel" />
      <remap from="set_object_transform" to="map/set_object_transform" />
    </node>
  </group>
</launch>
