<launch>
  <arg name="namespace" default="taluy" />
  <arg name="pipe_legacy_mask_topic" default="/seg_mask" />
  <arg name="pipe_legacy_cmd_vel_topic" default="cmd_vel" />

  <group ns="$(arg namespace)">
    <!-- YOLO Segmentation to Mask Node -->
    <node
      pkg="auv_vision"
      type="yolo_seg_to_mask.py"
      name="yolo_seg_to_mask_node"
      output="screen">
      <remap from="yolo_result_seg" to="/yolo_result_seg" />
      <param name="output_mask_topic" value="/seg_mask" />
    </node>

    <!-- Bottom Camera Segment Angle Node -->
    <node
      pkg="auv_detection"
      type="bottom_camera_segment_angle_node.py"
      name="bottom_camera_segment_angle_node"
      output="screen">
      <param name="mask_topic" value="/seg_mask" />
      <param name="measurement_topic" value="segment_measurement" />
      <param name="debug_topic" value="bottle_angle_debug" />
      <param name="min_bottle_area_px" value="1500" />
      <param name="min_contour_points" value="10" />
      <param name="publish_debug" value="true" />
    </node>

    <node
      pkg="auv_vision"
      type="dynamic_roll_compensation.py"
      name="dynamic_roll_compensation_node"
      output="screen">
      <remap from="odometry" to="odometry" />
      <remap from="camera/image_rect_color" to="cameras/cam_front/image_rect_color" />
      <remap from="camera/image_corrected" to="cameras/cam_front/image_corrected" />

      <param name="sync_queue_size" value="10"/>
      <param name="sync_slop" value="0.05"/>
      <param name="recalc_threshold_deg" value="0.1"/>
      <param name="camera_optical_frame" value="$(arg namespace)/base_link/front_camera_optical_link"/>
      <param name="camera_optical_frame_stabilized" value="$(arg namespace)/base_link/front_camera_optical_link_stabilized"/>
    </node>

    <node pkg="auv_vision" type="pipe_follower_legacy.py" name="pipe_follower_legacy" output="screen">
      <remap from="seg_mask" to="$(arg pipe_legacy_mask_topic)" />
      <remap from="cmd_vel" to="$(arg pipe_legacy_cmd_vel_topic)" />
      <remap from="debug_image/compressed" to="pipe_follower_legacy/debug_image/compressed" />
    </node>
  </group>
</launch>
