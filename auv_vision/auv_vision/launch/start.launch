<launch>
  <arg name="namespace" default="taluy" />

  <group ns="$(arg namespace)">
    <node
      pkg="auv_vision"
      type="dynamic_roll_compensation.py"
      name="dynamic_roll_compensation_node"
      output="screen">
      <remap from="sensors/imu/data" to="$(arg namespace)/sensors/imu/data" />
      <remap from="cameras/cam_front/image_raw" to="$(arg namespace)/cameras/cam_front/image_raw" />
      <remap from="cameras/cam_front/image_corrected" to="$(arg namespace)/cameras/cam_front/image_corrected" />
    </node>
  </group>
</launch>