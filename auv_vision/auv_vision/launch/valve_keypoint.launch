<?xml version="1.0"?>
<launch>
  <arg name="namespace"           default="taluy" />
  <arg name="image_topic"         default="/taluy/cameras/cam_front/image_raw" />
  <arg name="vitpose_model_path"  default="$(find auv_detection)/models/valve_vitpose.pth" />
  <arg name="yolo_model_path"     default="$(find auv_detection)/models/valve_yolo.pt" />
  <arg name="device"              default="cpu" />
  <arg name="conf_threshold"      default="0.5" />
  <arg name="yolo_conf_thres"     default="0.25" />
  <arg name="static_frame"        default="odom" />
  <arg name="control_rate"        default="10" />
  <arg name="use_sim_time"        default="false" />

  <!-- Pass start_cameras:=true on the AUV; leave false for laptop/bag testing
       where another producer publishes on $(arg image_topic). -->
  <arg name="start_cameras"           default="false" />
  <arg name="enable_localization"     default="true" />
  <arg name="enable_state_publisher"  default="true" />
  <arg name="sim"                     default="false" />

  <param name="/use_sim_time" value="$(arg use_sim_time)" />

  <include if="$(arg start_cameras)"
           file="$(find auv_bringup)/launch/inc/sensors/start_cameras_taluy.launch">
    <arg name="namespace" value="$(arg namespace)" />
  </include>

  <include if="$(arg enable_state_publisher)"
           file="$(find auv_bringup)/launch/inc/localization/start_state_publisher.launch.xml">
    <arg name="namespace" value="$(arg namespace)" />
  </include>

  <include if="$(arg enable_localization)"
           file="$(find auv_localization)/launch/start.launch">
    <arg name="namespace" value="$(arg namespace)" />
  </include>

  <include if="$(arg enable_localization)"
           file="$(find auv_bringup)/launch/robot_localization.launch">
    <arg name="namespace"    value="$(arg namespace)" />
    <arg name="control_rate" value="$(arg control_rate)" />
    <arg name="sim"          value="$(arg sim)" />
  </include>

  <group ns="$(arg namespace)">
    <node pkg="auv_vision" type="valve_keypoint_node.py"
          name="valve_keypoint_node" output="screen">
      <param name="image_topic"        value="$(arg image_topic)" />
      <param name="vitpose_model_path" value="$(arg vitpose_model_path)" />
      <param name="yolo_model_path"    value="$(arg yolo_model_path)" />
      <param name="device"             value="$(arg device)" />
      <param name="conf_threshold"     value="$(arg conf_threshold)" />
      <param name="yolo_conf_thres"    value="$(arg yolo_conf_thres)" />
      <param name="result_topic"       value="/keypoint_result_front" />
      <param name="image_out_topic"    value="/keypoint_image_front" />
    </node>

    <node pkg="auv_vision" type="keypoint_pose_node.py"
          name="keypoint_pose_node" output="screen">
      <param name="config_file"
             value="$(find auv_vision)/config/keypoint_objects.yaml" />
      <remap from="object_transform_updates"
             to="map/object_transform_updates" />
    </node>

    <node pkg="auv_mapping" type="object_map_tf_server_node"
          name="object_map_tf_server_node" output="screen">
      <param name="rate"                value="$(arg control_rate)" />
      <param name="static_frame"        value="$(arg static_frame)" />
      <param name="distance_threshold"  value="4.0" />
      <param name="base_link_frame"     value="$(arg namespace)/base_link" />
      <remap from="set_object_transform"      to="map/set_object_transform" />
      <remap from="clear_object_transforms"   to="map/clear_object_transforms" />
      <remap from="object_transform_updates"  to="map/object_transform_updates" />
    </node>

    <node pkg="auv_mapping" type="valve_trajectory_publisher.py"
          name="valve_trajectory_publisher" output="screen">
      <remap from="set_object_transform" to="map/set_object_transform" />
    </node>
  </group>
</launch>
