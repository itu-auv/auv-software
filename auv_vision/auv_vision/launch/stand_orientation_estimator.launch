<?xml version="1.0"?>
<launch>
    <!--
    Stand Orientation Estimator
    ============================
    Position: front camera bbox + known valve diameter (geometric estimation)
    Orientation: RealSense point cloud RANSAC (best-effort, uses valve position
                 as anchor to find stand surface in point cloud)
    -->

    <arg name="namespace" default="taluy" />

    <node name="stand_orientation_estimator"
          pkg="auv_vision"
          type="stand_orientation_estimator.py"
          output="screen">

        <!-- Namespace for frame/topic name construction -->
        <param name="namespace" value="$(arg namespace)" />

        <!-- Front camera: primary position source -->
        <param name="front_camera_info_topic" value="/$(arg namespace)/cameras/cam_front/camera_info" />
        <param name="front_optical_frame"     value="$(arg namespace)/base_link/front_camera_optical_link_stabilized" />
        <param name="valve_diameter"          value="0.24" />

        <!-- YoloResult: valve bbox (sim_bbox_node or real YOLO) -->
        <param name="bbox_topic"     value="/yolo_result_front" />
        <param name="valve_class_id" value="8" />

        <!-- RealSense: point cloud for RANSAC orientation -->
        <param name="cloud_topic"            value="/$(arg namespace)/camera/depth/color/points" />
        <param name="realsense_optical_frame" value="$(arg namespace)/camera_depth_optical_frame" />

        <!-- RANSAC parameters -->
        <param name="ransac_iterations"    value="300" />
        <param name="ransac_threshold"     value="0.03" />
        <param name="min_inlier_ratio"     value="0.3" />
        <param name="min_points_for_plane" value="50" />
        <param name="search_radius"        value="0.5" />
        <!-- Exclude points within this radius of valve center (skip valve body) -->
        <param name="valve_exclusion_radius" value="0.18" />

        <!-- Remap: publish to object_map_tf_server -->
        <remap from="object_transform_updates" to="map/set_object_transform" />
    </node>
</launch>
