<?xml version="1.0"?>
<launch>
    <!--
    Stand Orientation Estimator
    ============================
    RealSense stereo kamerasından noktabulutu ile
    valve standının oryantasyonunu hesaplar.
    -->

    <arg name="namespace" default="taluy" />

    <node name="stand_orientation_estimator"
          pkg="auv_vision"
          type="stand_orientation_estimator.py"
          output="screen">

        <!-- RealSense topic'leri -->
        <param name="color_topic" value="/$(arg namespace)/camera/color/image_raw" />
        <param name="cloud_topic" value="/$(arg namespace)/camera/depth/color/points" />

        <!-- Stand rengi: Sarı paneller (HSV) — oryantasyon için -->
        <rosparam param="hsv_lower">[20, 80, 80]</rosparam>
        <rosparam param="hsv_upper">[40, 255, 255]</rosparam>

        <!-- Valve rengi: Turuncu (HSV) — pozisyon için -->
        <rosparam param="valve_hsv_lower">[5, 150, 150]</rosparam>
        <rosparam param="valve_hsv_upper">[20, 255, 255]</rosparam>
        <param name="min_valve_area" value="200" />

        <!-- Tespit parametreleri -->
        <param name="min_contour_area" value="500" />
        <param name="morph_kernel_size" value="7" />

        <!-- RANSAC parametreleri -->
        <param name="ransac_iterations" value="300" />
        <param name="ransac_threshold" value="0.03" />
        <param name="min_inlier_ratio" value="0.3" />
        <param name="min_points_for_plane" value="50" />

        <!-- Debug -->
        <param name="publish_debug_image" value="true" />

        <!-- Remap: object_map_tf_server'a yaz -->
        <remap from="object_transform_updates" to="map/set_object_transform" />
    </node>
</launch>
