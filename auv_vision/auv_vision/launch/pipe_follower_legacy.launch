<launch>
    <!-- Simple launch file for the simplified pipe follower -->
    <arg name="namespace" default="taluy" />
    <arg name="mask_topic" default="bottle_mask" />
    <arg name="cmd_vel_topic" default="cmd_vel" />

    <group ns="$(arg namespace)">
        <node pkg="auv_vision" type="pipe_follower_legacy.py" name="pipe_follower_legacy" output="screen">
            <!-- Connections -->
            <remap from="seg_mask" to="$(arg mask_topic)" />
            <remap from="cmd_vel" to="$(arg cmd_vel_topic)" />
            <remap from="debug_image/compressed" to="pipe_follower_legacy/debug_image/compressed" />

            <!-- Parameters (using hardcoded defaults in code if not provided here) -->
            <param name="k_p" value="1.5" />
            <param name="max_angular_z" value="0.8" />
        </node>
    </group>
</launch>
