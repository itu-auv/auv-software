<?xml version="1.0"?>
<launch>
    <arg name="namespace" default="taluy" />
    <arg name="enable_rate" default="20" />
    <param name="/smach/max_linear_velocity" value="0.3" />
    <param name="/smach/max_angular_velocity" value="0.45" />

    <!-- State Mapping Definitions -->
    <arg name="state_map" default="
        init:INITIALIZE,
        gate:NAVIGATE_THROUGH_GATE,
        gate_mini:NAVIGATE_THROUGH_GATE_MINI,
        slalom:NAVIGATE_THROUGH_SLALOM,
        slalom_mini:NAVIGATE_THROUGH_SLALOM_MINI,
        torpedo:NAVIGATE_TO_TORPEDO_TASK,
        bin:NAVIGATE_TO_BIN_TASK,
        bin_mini:NAVIGATE_TO_BIN_MINI_TASK,
        octagon:NAVIGATE_TO_OCTAGON_TASK,
        gps:NAVIGATE_TO_GPS_TARGET,
        acoustic_tx:ACOUSTIC_TRANSMITTER,
        acoustic_rx:ACOUSTIC_RECEIVER,
        return:NAVIGATE_RETURN_THROUGH_GATE,
        pipeline:NAVIGATE_THROUGH_PIPELINE
    "/>

    <!-- Test Mode Configuration -->
    <arg name="test_mode" default="false" doc="Enable test mode for state machine"/>
    <arg name="roll" default="false" doc="Enable roll mode for state machine"/>
    <arg name="yaw" default="false" doc="Enable yaw mode for state machine"/>
    <arg name="coin_flip" default="false" doc="Enable coin flip mode for state machine"/>
    <arg name="mini_coin_flip" default="" doc="Gate mini start frame direction: turn_right, turn_left, turn_back, or empty"/>
    <arg name="slalom_depth" default="-1.1" />
    <arg name="mini_slalom_forward_velocity" default="0.25" />
    <arg name="mini_slalom_yaw_gain" default="1.0" />
    <arg name="mini_slalom_max_yaw_step_rad" default="0.0" />
    <arg name="mini_slalom_target_timeout_s" default="0.5" />
    <arg name="mini_slalom_lateral_strategy" default="none" />
    <arg name="mini_slalom_lateral_gain" default="0.0" />
    <arg name="mini_slalom_max_lateral_velocity" default="0.15" />
    <arg name="mini_slalom_min_runtime_s" default="5.0" />
    <arg name="mini_slalom_target_lost_success_timeout_s" default="1.5" />
    <arg name="mini_slalom_target_acquire_timeout_s" default="8.0" />
    <arg name="mini_slalom_max_runtime_s" default="25.0" />
    <arg name="mini_slalom_min_travel_distance_m" default="4.0" />
    <arg name="mini_slalom_premature_target_lost_abort_timeout_s" default="3.0" />

    <!-- Full Mission States -->
    <arg name="full_mission_states" default="[
        'INITIALIZE',
        'NAVIGATE_THROUGH_GATE',
        'NAVIGATE_THROUGH_SLALOM',
        'NAVIGATE_TO_TORPEDO_TASK',
        'NAVIGATE_TO_BIN_TASK',
        'NAVIGATE_TO_BIN_MINI_TASK',
        'NAVIGATE_TO_OCTAGON_TASK',
        'NAVIGATE_TO_GPS_TARGET',
        'ACOUSTIC_TRANSMITTER',
        'ACOUSTIC_RECEIVER',
        'NAVIGATE_RETURN_THROUGH_GATE',
        'NAVIGATE_THROUGH_PIPELINE'
    ]" doc="Full sequence of mission states"/>

    <!-- Test Mission States -->
    <arg name="test_states" default="[
        'init'
    ]" doc="States to execute in test mode"/>

    <group ns="$(arg namespace)">
        <!-- Main State Machine Node -->
        <node name="main_state_machine" pkg="auv_smach" type="main_state_machine.py" output="screen">
            <remap from="propulsion_board/status" to="propulsion_board/status"/>
            <param name="~base_link" value="$(arg namespace)/base_link"/>
            <param name="roll" value="$(arg roll)"/>
            <param name="yaw" value="$(arg yaw)"/>
            <param name="coin_flip" value="$(arg coin_flip)"/>
            <param name="mini_coin_flip" value="$(arg mini_coin_flip)"/>
            <param name="slalom_depth" value="$(arg slalom_depth)"/>
            <param name="mini_slalom_forward_velocity" value="$(arg mini_slalom_forward_velocity)"/>
            <param name="mini_slalom_yaw_gain" value="$(arg mini_slalom_yaw_gain)"/>
            <param name="mini_slalom_max_yaw_step_rad" value="$(arg mini_slalom_max_yaw_step_rad)"/>
            <param name="mini_slalom_target_timeout_s" value="$(arg mini_slalom_target_timeout_s)"/>
            <param name="mini_slalom_lateral_strategy" value="$(arg mini_slalom_lateral_strategy)"/>
            <param name="mini_slalom_lateral_gain" value="$(arg mini_slalom_lateral_gain)"/>
            <param name="mini_slalom_max_lateral_velocity" value="$(arg mini_slalom_max_lateral_velocity)"/>
            <param name="mini_slalom_min_runtime_s" value="$(arg mini_slalom_min_runtime_s)"/>
            <param name="mini_slalom_target_lost_success_timeout_s" value="$(arg mini_slalom_target_lost_success_timeout_s)"/>
            <param name="mini_slalom_target_acquire_timeout_s" value="$(arg mini_slalom_target_acquire_timeout_s)"/>
            <param name="mini_slalom_max_runtime_s" value="$(arg mini_slalom_max_runtime_s)"/>
            <param name="mini_slalom_min_travel_distance_m" value="$(arg mini_slalom_min_travel_distance_m)"/>
            <param name="mini_slalom_premature_target_lost_abort_timeout_s" value="$(arg mini_slalom_premature_target_lost_abort_timeout_s)"/>

            <!-- common.py -->
            <remap from="clear_object_transforms" to="map/clear_object_transforms"/>
            <remap from="torpedo_1/launch" to="actuators/torpedo_1/launch"/>
            <remap from="torpedo_2/launch" to="actuators/torpedo_2/launch"/>
            <remap from="ball_dropper/drop" to="actuators/ball_dropper/drop"/>
            <remap from="align_frame/cancel" to="control/align_frame/cancel"/>
            <remap from="align_frame/start" to="control/align_frame/start"/>
            <remap from="enable" to="enable"/>
            <remap from="propulsion_board/status" to="propulsion_board/status"/>
            <remap from="odometry" to="odometry"/>
            <remap from="cmd_vel" to="cmd_vel"/>

            <!-- camera_detection_pose_estimator.py -->
            <remap from="enable_front_camera_detections" to="vision/enable_front_camera_detections"/>
            <remap from="enable_bottom_camera_detections" to="vision/enable_bottom_camera_detections"/>
            <remap from="enable_slalom_camera_detections" to="vision/enable_slalom_camera_detections"/>
            <remap from="enable_torpedo_camera_detections" to="vision/enable_torpedo_camera_detections"/>
            <remap from="enable_segment_camera_detections" to="vision/enable_segment_camera_detections"/>
            <remap from="set_front_camera_focus" to="vision/set_front_camera_focus"/>
            <remap from="set_bottom_camera_focus" to="vision/set_bottom_camera_focus"/>
            <remap from="enable_realsense_publisher" to="/process_tracker_with_cloud/enable"/>

            <!-- slalom_mini.py -->
            <remap from="slalom/target" to="slalom/target"/>
            <remap from="slalom_controller/set_enabled" to="slalom_controller/set_enabled"/>
            <remap from="slalom_controller/stop" to="slalom_controller/stop"/>

            <param name="enable_rate" value="$(arg enable_rate)"/>

            <!-- gate.py -->
            <remap from="set_transform_gate_trajectory" to="toggle_gate_trajectory"/>
            <remap from="toggle_coin_flip_rescuer" to="toggle_coin_flip_rescuer" />
            <remap from="odometry" to="odometry"/>
            <remap from="wrench" to="wrench"/>
            <remap from="toggle_gate_trajectory" to="toggle_gate_trajectory"/>
            <remap from="toggle_mini_gate_trajectory" to="toggle_mini_gate_trajectory"/>
            <remap from="dvl_to_odom_node/enable" to="dvl_to_odom_node/enable"/>

            <!--initialize.py-->
            <remap from="set_depth" to="set_depth"/>
            <remap from="set_pose" to="set_pose"/>
            <remap from="reset_odometry" to="reset_odometry"/>
            <remap from="dvl/enable" to="sensors/dvl/enable"/>
            <remap from="localization_enable" to="auv_localization_node/enable"/>

            <!--red_buoy.py-->
            <remap from="set_object_transform" to="map/set_object_transform"/>

            <!--bin.py-->
            <remap from="toggle_bin_trajectory" to="toggle_bin_trajectory"/>

            <!--pipeline.py-->
            <remap from="toggle_pipeline_trajectory" to="toggle_pipeline_trajectory"/>

            <!--acoustic.py-->
            <remap from="modem/data/rx" to="modem/data/rx"/>

            <!-- octagon.py Gripper Service -->
            <remap from="actuators/gripper/close" to="actuators/gripper/close"/>

            <param name="test_mode" value="$(arg test_mode)"/>
            <rosparam param="state_map" subst_value="true">$(arg state_map)</rosparam>
            <rosparam param="full_mission_states" subst_value="true">$(arg full_mission_states)</rosparam>
            <param name="test_states" value="$(arg test_states)"/>
            <!-- Load path planner parameters in the node -->
            <rosparam file="$(find auv_navigation)/config/path_planner_config.yaml" command="load"/>
        </node>
    </group>
</launch>
