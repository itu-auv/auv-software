material Task5RepairMaterial
{
  technique
  {
    pass
    {
      lighting off
      scene_blend alpha_blend
      depth_write off
      alpha_rejection greater_equal 128
      cull_hardware clockwise
      texture_unit
      {
        texture Task5_Repair.png
        filtering anisotropic
      }
    }
  }
}

