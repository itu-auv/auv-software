<?xml version="1.0"?>
<sdf version="1.6">
  <model name="electric">
    <pose>0 0 0 0 0 0</pose>
    <static>true</static>

  <link name="electric_link">
      <pose>0 0 0 0 0 0</pose>

      <!-- Primary visual (untextured DAE mesh) -->
  <visual name="electric_vis_base">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://electric/meshes/electric.dae</uri>
          </mesh>
        </geometry>
      </visual>

      <!-- Decal visuals to display the texture on the caps -->
  <visual name="electric_vis_decal_top">
        <pose>0 0 0.0305 0 0 0</pose>
        <geometry>
          <box><size>0.087 0.087 0.001</size></box>
        </geometry>
        <material>
          <script>
            <uri>model://electric/materials/scripts</uri>
            <uri>model://electric/materials/textures</uri>
            <name>Task5ElectricMaterial</name>
          </script>
        </material>
      </visual>

  <visual name="electric_vis_decal_bot">
        <pose>0 0 -0.0025 0 3.14159 0</pose>
        <geometry>
          <box><size>0.087 0.087 0.001</size></box>
        </geometry>
        <material>
          <script>
            <uri>model://electric/materials/scripts</uri>
            <uri>model://electric/materials/textures</uri>
            <name>Task5ElectricMaterial</name>
          </script>
        </material>
      </visual>

    </link>
  </model>
</sdf>
