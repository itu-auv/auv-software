material OctagonRedCrossMaterial
{
  receive_shadows off
  technique
  {
    pass
    {
      lighting off
      ambient 1.0 1.0 1.0 1.0
      diffuse 1.0 1.0 1.0 1.0

      texture_unit
      {
        texture Task5_RedCross.png
        filtering trilinear
      }
    }
  }
}

material OctagonWarningMaterial
