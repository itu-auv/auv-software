<launch>
    <arg name="namespace" default="taluy"/>

    <!-- Topics -->
    <arg name="cmd_wrench_topic" default="cmd_wrench"/>
    <arg name="odom_topic" default="odometry"/>
    <arg name="wrench_topic" default="wrench"/>
    <arg name="accel_topic" default="acceleration"/>

    <!-- Test Parameters -->
    <arg name="pre_hold_time" default="2.0"/>
    <arg name="record_time" default="20.0"/>
    <arg name="log_dir" default="$(env HOME)/added_mass_tests"/>

    <group ns="$(arg namespace)">
        <node pkg="auv_control" type="added_mass_tester.py" name="added_mass_tester" output="screen">
            <param name="cmd_wrench_topic" value="$(arg cmd_wrench_topic)" />
            <param name="odom_topic" value="$(arg odom_topic)" />
            <param name="wrench_topic" value="$(arg wrench_topic)" />
            <param name="accel_topic" value="$(arg accel_topic)" />

            <param name="pre_hold_time" value="$(arg pre_hold_time)" />
            <param name="record_time" value="$(arg record_time)" />
            <param name="log_dir" value="$(arg log_dir)" />
        </node>
    </group>
</launch>
